{
  "groups": [
    {
      "name": "easy-agent.core",
      "type": "java.lang.Void",
      "sourceType": "io.github.songrongzhen.easyagent.autoconfigure.EasyAgentCoreAutoConfiguration"
    },
    {
      "name": "easy-agent.rag",
      "type": "io.github.songrongzhen.easyagent.rag.config.EasyAgentRagProperties",
      "sourceType": "io.github.songrongzhen.easyagent.rag.config.EasyAgentRagProperties"
    },
    {
      "name": "easy-agent.mcp",
      "type": "io.github.songrongzhen.easyagent.mcp.config.EasyAgentMcpProperties",
      "sourceType": "io.github.songrongzhen.easyagent.mcp.config.EasyAgentMcpProperties"
    },
    {
      "name": "easy-agent.skill",
      "type": "io.github.songrongzhen.easyagent.skill.config.EasyAgentSkillProperties",
      "sourceType": "io.github.songrongzhen.easyagent.skill.config.EasyAgentSkillProperties"
    },
    {
      "name": "easy-agent.llm",
      "type": "io.github.songrongzhen.easyagent.llm.config.EasyAgentLlmProperties",
      "sourceType": "io.github.songrongzhen.easyagent.llm.config.EasyAgentLlmProperties"
    }
  ],
  "properties": [
    {
      "name": "easy-agent.rag.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable RAG module"
    },
    {
      "name": "easy-agent.rag.storage-type",
      "type": "io.github.songrongzhen.easyagent.rag.config.EasyAgentRagProperties$StorageType",
      "defaultValue": "AUTO",
      "description": "Vector store type: AUTO, PGVECTOR, PDF, IN_MEMORY"
    },
    {
      "name": "easy-agent.rag.pdf.resource-path",
      "type": "java.lang.String",
      "defaultValue": "classpath:knowledge/",
      "description": "Path to PDF knowledge base files"
    },
    {
      "name": "easy-agent.mcp.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable MCP module"
    },
    {
      "name": "easy-agent.mcp.sse-endpoint",
      "type": "java.lang.String",
      "defaultValue": "/mcp/sse",
      "description": "MCP SSE endpoint path"
    },
    {
      "name": "easy-agent.skill.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable Skill module"
    },
    {
      "name": "easy-agent.skill.skill-path",
      "type": "java.lang.String",
      "defaultValue": "classpath:skills/",
      "description": "Path to SKILL.md files"
    },
    {
      "name": "easy-agent.skill.hot-reload",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable hot-reload for SKILL.md files"
    },
    {
      "name": "easy-agent.llm.enabled",
      "type": "java.lang.Boolean",
      "defaultValue": true,
      "description": "Enable LLM module"
    },
    {
      "name": "easy-agent.llm.provider",
      "type": "io.github.songrongzhen.easyagent.llm.config.EasyAgentLlmProperties$LlmProvider",
      "defaultValue": "NONE",
      "description": "LLM provider: NONE, DASHSCOPE, DEEPSEEK, OLLAMA, OPENAI"
    },
    {
      "name": "easy-agent.llm.dash-scope.api-key",
      "type": "java.lang.String",
      "description": "DashScope API key"
    },
    {
      "name": "easy-agent.llm.deep-seek.api-key",
      "type": "java.lang.String",
      "description": "DeepSeek API key"
    },
    {
      "name": "easy-agent.llm.ollama.base-url",
      "type": "java.lang.String",
      "defaultValue": "http://localhost:11434",
      "description": "Ollama base URL"
    }
  ]
}
